{
  "name": "@agarwal-ai/governance",
  "version": "1.0.0",
  "description": "Governance & Trust Mesh plugin — policy enforcement, explainability, compliance, safety boundaries",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["governance", "trust", "compliance", "safety", "explainability", "ai-ethics"],
  "license": "MIT",
  "dependencies": {
    "@agarwal-ai/core": "workspace:*"
  }
}
